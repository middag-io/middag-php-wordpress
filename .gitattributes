# Normalize line endings — LF in the repo, auto on checkout.
* text=auto eol=lf

# Keep `composer install --prefer-dist` archives lean: ship runtime code only,
# strip dev/CI/tooling artifacts from distribution tarballs.
/.cache                             export-ignore
/.claude                            export-ignore
/.githooks                          export-ignore
/.github                            export-ignore
/.gitattributes                     export-ignore
/.gitignore                         export-ignore
/.planning                          export-ignore
/.specify                           export-ignore
/.php-cs-fixer.dist.php             export-ignore
/.php-rector.php                    export-ignore
/.phpstan.neon                      export-ignore
/.phpunit.cache                     export-ignore
/phpstan-baseline.neon              export-ignore
/.release-please-manifest.json      export-ignore
/release-please-config.json         export-ignore
/phpunit.xml                        export-ignore
/bin                                export-ignore
/tests                              export-ignore
/docs                               export-ignore
/CHANGELOG.md                       export-ignore
/CLAUDE.md                          export-ignore
/CODE_OF_CONDUCT.md                 export-ignore
/CONTRIBUTING.md                    export-ignore
/SECURITY.md                        export-ignore

# Keep GitHub's language statistics accurate — documentation is not code.
*.md                                linguist-documentation
docs/**                             linguist-documentation
